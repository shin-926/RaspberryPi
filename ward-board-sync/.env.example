# Henry Firebase Auth (extracted from browser IndexedDB: firebaseLocalStorageDb)
HENRY_FIREBASE_API_KEY=
HENRY_FIREBASE_REFRESH_TOKEN=

# Henry organization
HENRY_ORG_UUID=ce6b556b-2a8d-4fce-b8dd-89ba638fc825
HENRY_GRAPHQL_ENDPOINT=https://henry-app.jp/graphql

# Firestore project (same as web app)
FIREBASE_PROJECT_ID=maokahp-webapps

# Token cache file (auto-managed; do NOT commit)
TOKEN_CACHE_PATH=./.secrets/token-cache.json

# Optional: Uptime Kuma push URL (for heartbeat + error notification)
# Create a "Push" monitor in Uptime Kuma → copy the push URL here
# Leave empty to disable
UPTIME_KUMA_PUSH_URL=
